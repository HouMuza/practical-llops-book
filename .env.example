# Copy to .env and fill in. Never commit .env (it is gitignored).
SUBSCRIPTION_ID=
RESOURCE_GROUP=llmops-book-rg
WORKSPACE_NAME=llmops-book-mlw
AML_LOCATION=westeurope
ENDPOINT_NAME=qwen3-yourname-prod

# Optional: LLM-as-judge eval (OpenAI or Azure OpenAI)
JUDGE_API_KEY=
JUDGE_ENDPOINT=https://api.openai.com/v1/chat/completions
JUDGE_MODEL=gpt-4o-mini

# Optional: Hugging Face (higher rate limits for model download in container)
HF_TOKEN=

# Optional: Azure alerts workflow
ACTION_GROUP_ID=
