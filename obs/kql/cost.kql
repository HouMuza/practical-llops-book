customMetrics
| where name in ("input_tokens", "output_tokens", "gpu_replica_hours")
| summarize total=sum(value) by name, bin(timestamp, 1d), tostring(customDimensions.tenant_id)
| evaluate pivot(name, sum(total))
| extend cost_per_1k_tokens = gpu_replica_hours / ((input_tokens + output_tokens) / 1000.0)
| order by timestamp desc
